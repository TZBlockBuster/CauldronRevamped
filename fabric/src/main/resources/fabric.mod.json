{
  "schemaVersion": 1,
  "id": "cauldronrevamped",
  "version": "${version}",
  "name": "CauldronRevamped",
  "description": "CauldronRevamped reworks the vanilla cauldron, while keeping it as vanilla as possible. It adds the ability to mix potions inside the cauldron.",
  "authors": [
    "TZBlockBuster"
  ],
  "contact": {
    "sources": "https://github.com/TZBlockBuster/CauldronRevamped",
    "issues": "https://github.com/TZBlockBuster/CauldronRevamped/issues"
  },
  "license": "MIT",
  "icon": "assets/cauldronrevamped/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "de.tzblockbuster.cauldronrevamped.fabric.CauldronRevampedFabric"
    ],
    "client": [
      "de.tzblockbuster.cauldronrevamped.fabric.client.CauldronRevampedFabricClient"
    ],
    "fabric-datagen": [
      "de.tzblockbuster.cauldronrevamped.fabric.client.datagen.CauldronRevampedDataGenerator"
    ]
  },
  "mixins": [
    "cauldronrevamped.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "architectury": ">=19.0.1",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
